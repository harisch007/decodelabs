import string

def check_password_strength(password):

   
    # check password length
    if len(password) < 8:
        return "WEAK (Length is less than 8 characters)"
    
    #  Pattern Recognition using Pythonic Elegance

    has_upper  = any(char.isupper() for char in password)
    has_digit  = any(char.isdigit() for char in password)
    has_symbol = any(char in string.punctuation for char in password)
    
    # checking how many security layers are met
    security_score = sum([has_upper, has_digit, has_symbol])
    
    if security_score == 3:
        return "STRONG (Excellent entropy and pattern diversity)"
    elif security_score == 2:
        return "MEDIUM (Good, but try adding more character variety)"
    else:
        return "WEAK (Fails baseline complexity requirements)"


